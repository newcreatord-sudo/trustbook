SUPABASE_ACCESS_TOKEN=
# Opzionale se l’URL Supabase non è nel formato xxx.supabase.co
SUPABASE_PROJECT_REF=

# Opzionale solo dev locale (mai produzione): imposta AUTH_DEV_SIGNUP_CONFIRMED=true per registrarti senza email di conferma (con `npm run dev` il client usa l’API che crea utenti già confermati).

