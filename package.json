{
  "name": "trustbook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build": "node ./scripts/vercel-prebuild.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "typecheck": "npm run check",
    "db:verify-owner-strict": "node ./scripts/db-owner-strict-check.mjs",
    "db:verify-booking-flow": "node ./scripts/db-booking-flow-check.mjs",
    "db:verify-booking-integrity": "node ./scripts/db-booking-integrity-check.mjs",
    "db:verify-rls-impersonation": "node ./scripts/db-rls-impersonation-check.mjs",
    "db:audit:rls": "node ./scripts/db-audit-rls.mjs",
    "db:audit:rls:production": "node ./scripts/db-audit-rls.mjs --env-file=.env.production",
    "db:ssl:fetch-ca:production": "node ./scripts/fetch-db-ca-bundle.mjs --env-file=.env.production --out=artifacts/db-ca-bundle.production.pem",
    "db:ssl:fetch-ca:staging": "node ./scripts/fetch-db-ca-bundle.mjs --env-file=.env.staging --out=artifacts/db-ca-bundle.staging.pem",
    "db:apply-all": "node ./scripts/db-apply-all-migrations.mjs",
    "db:apply-all:staging": "node ./scripts/db-apply-all-migrations.mjs --env-file=.env.staging",
    "db:apply-all:production": "node ./scripts/db-apply-all-migrations.mjs --env-file=.env.production",
    "db:apply-critical": "node ./scripts/db-apply-critical-migrations.mjs",
    "db:apply-critical:staging": "node ./scripts/db-apply-critical-migrations.mjs --env-file=.env.staging",
    "db:apply-critical:production": "node ./scripts/db-apply-critical-migrations.mjs --env-file=.env.production",
    "db:apply-saas": "node ./scripts/db-apply-saas-migrations.mjs",
    "auth:templates:dry-run": "node ./scripts/push-auth-email-templates.mjs",
    "auth:templates:verify-remote": "node ./scripts/push-auth-email-templates.mjs --verify",
    "auth:templates:push": "node ./scripts/push-auth-email-templates.mjs --live",
    "auth:templates:sync": "node ./scripts/push-auth-email-templates.mjs --live --verify",
    "setup:auth-complete": "node ./scripts/setup-auth-complete.mjs",
    "verify:repo": "npm run lint && npm run check && npm run test && npm run build",
    "api:verify-auth-email": "node ./scripts/verify-auth-email-api.mjs",
    "api:verify-auth-email:staging": "node ./scripts/verify-auth-email-api.mjs --env-file=.env.staging",
    "api:verify-auth-email:production": "node ./scripts/verify-auth-email-api.mjs --env-file=.env.production",
    "env:validate": "node ./scripts/validate-deploy-env.mjs",
    "env:validate:staging": "node ./scripts/validate-deploy-env.mjs --env-file=.env.staging",
    "env:validate:production": "node ./scripts/validate-deploy-env.mjs --env-file=.env.production",
    "env:validate:payments:staging": "node ./scripts/validate-deploy-env.mjs --env-file=.env.staging --require-payments",
    "env:validate:payments:production": "node ./scripts/validate-deploy-env.mjs --env-file=.env.production --require-payments",
    "env:validate:saas:staging": "node ./scripts/validate-deploy-env.mjs --env-file=.env.staging --require-stripe-saas",
    "env:validate:saas:production": "node ./scripts/validate-deploy-env.mjs --env-file=.env.production --require-stripe-saas",
    "env:stripe:open-staging": "node ./scripts/open-env-edit-file.mjs staging",
    "env:stripe:open-production": "node ./scripts/open-env-edit-file.mjs production",
    "env:stripe:merge": "node ./scripts/merge-stripe-env.mjs",
    "vapid:generate": "node ./scripts/generate-vapid-keys.mjs",
    "stripe:bootstrap:saas:staging": "node ./scripts/stripe-bootstrap-saas-plans.mjs --env-file=.env.staging",
    "stripe:bootstrap:saas:production": "node ./scripts/stripe-bootstrap-saas-plans.mjs --env-file=.env.production",
    "test": "vitest run",
    "check:tests:integrity": "node ./scripts/check-tests-integrity.mjs",
    "check:migrations:integrity": "node ./scripts/check-migrations-integrity.mjs",
    "audit:service-role": "node ./scripts/audit-service-role-usage.mjs",
    "audit:security": "npm run audit:service-role && npm audit --audit-level=high",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install --with-deps chromium webkit",
    "test:critical-owner-onboarding": "vitest run src/pages/onboarding/BusinessOnboarding.ownerFlow.test.tsx src/lib/businessSetup.onboardingOwner.test.ts src/lib/bookingRules.test.ts src/utils/antiNoShowEngine.test.ts",
    "test:onboarding-owner": "vitest run src/lib/businessSetup.onboardingOwner.test.ts",
    "test:onboarding-ui": "vitest run src/pages/onboarding/BusinessOnboarding.ownerFlow.test.tsx",
    "test:onboarding-policy-guard": "vitest run src/pages/onboarding/OnboardingPolicyGuard.test.tsx",
    "test:qa:flows:core": "vitest run src/pages/Login.customerFlow.test.tsx src/pages/Home.searchFlow.test.tsx src/pages/business/BookingPanel.flow.test.tsx src/pages/Bookings.customerFlow.test.tsx src/pages/Mobile.smoke.test.tsx src/pages/AppEntry.test.tsx src/pages/dashboard/BusinessCalendarView.test.tsx src/pages/onboarding/OnboardingPolicyGuard.test.tsx src/pages/onboarding/BusinessOnboarding.ownerFlow.test.tsx",
    "test:qa:flows": "vitest run src/pages/Login.customerFlow.test.tsx src/pages/Home.searchFlow.test.tsx src/pages/business/BookingPanel.flow.test.tsx src/pages/Bookings.customerFlow.test.tsx src/pages/Mobile.smoke.test.tsx src/pages/AppEntry.test.tsx src/pages/dashboard/BusinessCalendarView.test.tsx src/pages/onboarding/OnboardingPolicyGuard.test.tsx src/pages/onboarding/BusinessOnboarding.ownerFlow.test.tsx src/pages/BusinessDashboard.bookingActions.test.tsx src/pages/BusinessPayments.test.tsx api/routes/stripe.test.ts",
    "test:api-critical:core": "vitest run api/routes/auth.test.ts",
    "test:api-critical": "vitest run api/routes/auth.test.ts api/routes/stripe.test.ts",
    "check:business-dashboard:bootstrap": "node ./scripts/check-business-dashboard-bootstrap-budget.mjs",
    "test:business-dashboard:perf": "vitest run src/pages/BusinessDashboard.bootstrapPerf.test.tsx",
    "check:bundle:google-maps": "node ./scripts/check-google-maps-bundle-budget.mjs",
    "verify:local:strict": "npm run check && npm run lint && npm run check:tests:integrity && npm run check:business-dashboard:bootstrap && npm run test:business-dashboard:perf && npm run test:onboarding-policy-guard && npm run test:qa:flows && npm run test:critical-owner-onboarding && npm test && npm run build && npm run check:bundle:google-maps",
    "gate:release": "node ./scripts/release-gate.mjs",
    "gate:release:strict": "node ./scripts/release-gate.mjs --strict-db",
    "release:hardened": "node ./scripts/release-hardened.mjs",
    "gate:release:staging": "node ./scripts/release-gate.mjs --strict-db --env-file=.env.staging",
    "gate:release:production": "node ./scripts/release-gate.mjs --strict-db --env-file=.env.production",
    "release:hardened:staging": "node ./scripts/release-hardened.mjs --env-file=.env.staging",
    "release:hardened:production": "node ./scripts/release-hardened.mjs --env-file=.env.production",
    "deploy:preflight:staging": "npm run env:validate:staging && npm run api:verify-auth-email:staging && npm run gate:release:staging",
    "deploy:preflight:production": "npm run env:validate:production && npm run api:verify-auth-email:production && npm run gate:release:production",
    "deploy:hardened:staging": "npm run env:validate:staging && npm run release:hardened:staging",
    "deploy:hardened:production": "npm run env:validate:production && npm run release:hardened:production",
    "deploy:payments:preflight:staging": "npm run env:validate:payments:staging && npm run deploy:preflight:staging",
    "deploy:payments:preflight:production": "npm run env:validate:payments:production && npm run deploy:preflight:production",
    "deploy:payments:hardened:staging": "npm run env:validate:payments:staging && npm run deploy:hardened:staging",
    "deploy:payments:hardened:production": "npm run env:validate:payments:production && npm run deploy:hardened:production",
    "test:watch": "vitest",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "@sentry/node": "^8.45.0",
    "@sentry/react": "^8.45.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/query-sync-storage-persister": "^5.59.20",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-query-persist-client": "^5.59.20",
    "@vis.gl/react-google-maps": "^1.8.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "i18next": "^23.16.4",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^1.14.0",
    "nodemailer": "^8.0.7",
    "posthog-js": "^1.196.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "react-router-dom": "^7.3.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.0.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@axe-core/react": "^4.10.0",
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.10",
    "pg": "^8.20.0",
    "postcss": "^8.5.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.3.0"
  }
}
